@page "/"
@rendermode InteractiveServer
@using System.Text.Json
@using DinoAI.Core.Agents
@using DinoAI.Core.Sessions
@using DinoAI.Core.Tools
@using DinoAI.Core.Workspace
@inject IAgentSessionStore Sessions
@inject IAgentRunner Agent
@inject IWorkspaceService Workspace
@inject IAgentToolRegistry Tools

<PageTitle>DinoAI</PageTitle>

<section class="dino-app">
    <aside class="session-sidebar">
        <div class="sidebar-heading">
            <div>
                <p class="eyebrow">Sessions</p>
                <h2>DinoAI</h2>
            </div>
            <button class="icon-button" title="New session" @onclick="CreateSessionAsync">+</button>
        </div>

        <div class="session-list">
            @if (SessionList.Count == 0)
            {
                <p class="empty small">No sessions yet.</p>
            }
            else
            {
                @foreach (var session in SessionList)
                {
                    <button class="session-tab @(ActiveSession?.Id == session.Id ? "active" : null)" @onclick="() => SelectSessionAsync(session.Id)">
                        <strong>@session.Title</strong>
                        <span>@session.Messages.Count message(s)</span>
                        <time>@session.UpdatedAt.LocalDateTime.ToString("g")</time>
                    </button>
                }
            }
        </div>
    </aside>

    <main class="dino-shell">
        <header class="dino-header">
            <div>
                <p class="eyebrow">DinoAI Agent</p>
                <h1>Local C# AI coding workspace</h1>
                <p class="summary">Agent turns flow through DinoAI.Core: sessions, local planning, permissions, workspace tools, and shell checks.</p>
            </div>
            <button class="primary" @onclick="CreateSessionAsync">New session</button>
        </header>

        <section class="workspace-panel">
            <div>
                <p class="eyebrow">Workspace</p>
                <h2>@WorkspaceRoot</h2>
                <p class="summary">Found @ProjectFiles.Count project file(s) outside ignored folders.</p>
            </div>
            <div class="project-list">
                @foreach (var file in ProjectFiles)
                {
                    <span>@file.RelativePath</span>
                }
            </div>
        </section>

        <section class="tools-panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Tools</p>
                    <h2>Manual Tool Execution</h2>
                </div>
                <span>@ToolDefinitions.Count tool(s)</span>
            </div>

            <div class="tool-list">
                @foreach (var tool in ToolDefinitions)
                {
                    <span title="@tool.Description">@tool.Name</span>
                }
            </div>

            <div class="tool-runner">
                <label>
                    Tool
                    <select value="@SelectedToolName" @onchange="OnSelectedToolChanged">
                        @foreach (var tool in ToolDefinitions)
                        {
                            <option value="@tool.Name">@tool.Name</option>
                        }
                    </select>
                </label>

                <label>
                    Workspace root
                    <input @bind="WorkspaceRoot" @bind:event="oninput" />
                </label>

                <label class="approval-toggle">
                    <input type="checkbox" @bind="ToolApproved" />
                    Explicitly approve this tool call
                </label>

                @if (SelectedTool is not null)
                {
                    <div class="tool-description">
                        <strong>@SelectedTool.Name</strong>
                        <span>@SelectedTool.Description</span>
                    </div>

                    <div class="parameter-list">
                        @foreach (var parameter in SelectedTool.Parameters)
                        {
                            <span>@parameter.Name @(parameter.IsRequired ? "required" : $"default {parameter.DefaultValue}")</span>
                        }
                    </div>
                }

                <label>
                    Arguments
                    <textarea @bind="ToolArgumentsText" @bind:event="oninput" rows="5" placeholder="key=value&#10;command=git status --short&#10;timeoutSeconds=30"></textarea>
                </label>

                <button class="primary" @onclick="ExecuteSelectedToolAsync" disabled="@(IsToolBusy || string.IsNullOrWhiteSpace(SelectedToolName))">
                    @(IsToolBusy ? "Running tool..." : "Run tool")
                </button>

                @if (!string.IsNullOrWhiteSpace(ToolResultJson))
                {
                    <pre class="tool-result @(LastToolSucceeded ? "success" : "failure")">@ToolResultJson</pre>
                }
            </div>
        </section>

        <div class="composer">
            <input @bind="DraftMessage" @bind:event="oninput" placeholder="Try: /workspace, /files *.csproj, /read README.md, /status, /build" />
            <button @onclick="SendMessageAsync" disabled="@(ActiveSession is null || IsBusy || string.IsNullOrWhiteSpace(DraftMessage))">
                @(IsBusy ? "Running..." : "Send")
            </button>
        </div>

        @if (ActiveSession is null)
        {
            <p class="empty">Create a session to start the workspace loop.</p>
        }
        else
        {
            <article class="session">
                <h2>@ActiveSession.Title</h2>
                <p class="session-id">@ActiveSession.Id</p>

                <div class="messages">
                    @foreach (var message in ActiveSession.Messages)
                    {
                        <div class="message @message.Role.ToString().ToLowerInvariant()">
                            <strong>@message.Role</strong>
                            <span>@message.Content</span>
                        </div>
                    }
                </div>
            </article>
        }
    </main>
</section>

@code {
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web)
    {
        WriteIndented = true
    };

    private AgentSession? ActiveSession { get; set; }

    private string DraftMessage { get; set; } = string.Empty;

    private string WorkspaceRoot { get; set; } = WorkspaceRootResolver.Resolve(Directory.GetCurrentDirectory());

    private bool IsBusy { get; set; }

    private bool IsToolBusy { get; set; }

    private bool ToolApproved { get; set; }

    private bool LastToolSucceeded { get; set; }

    private string SelectedToolName { get; set; } = string.Empty;

    private string ToolArgumentsText { get; set; } = "command=git status --short";

    private string? ToolResultJson { get; set; }

    private IReadOnlyList<AgentSession> SessionList { get; set; } = [];

    private IReadOnlyList<WorkspaceFile> ProjectFiles { get; set; } = [];

    private IReadOnlyList<AgentToolDefinition> ToolDefinitions { get; set; } = [];

    private AgentToolDefinition? SelectedTool => ToolDefinitions.FirstOrDefault(tool => tool.Name == SelectedToolName);

    protected override async Task OnInitializedAsync()
    {
        await RefreshSessionsAsync();
        ActiveSession = SessionList.FirstOrDefault() ?? await Sessions.CreateAsync("Blazor workspace session");
        await RefreshSessionsAsync();
        ProjectFiles = await Workspace.FindFilesAsync(WorkspaceRoot, "*.csproj", 20);
        ToolDefinitions = Tools.List();
        SelectedToolName = ToolDefinitions.FirstOrDefault()?.Name ?? string.Empty;
    }

    private async Task RefreshSessionsAsync()
    {
        SessionList = await Sessions.ListAsync();
    }

    private async Task CreateSessionAsync()
    {
        ActiveSession = await Sessions.CreateAsync("Blazor workspace session");
        DraftMessage = string.Empty;
        await RefreshSessionsAsync();
    }

    private async Task SelectSessionAsync(Guid sessionId)
    {
        ActiveSession = await Sessions.GetAsync(sessionId);
        DraftMessage = string.Empty;
    }

    private async Task SendMessageAsync()
    {
        if (ActiveSession is null || string.IsNullOrWhiteSpace(DraftMessage))
        {
            return;
        }

        IsBusy = true;
        var message = DraftMessage;
        DraftMessage = string.Empty;

        try
        {
            var result = await Agent.RunAsync(ActiveSession.Id, WorkspaceRoot, message);
            ActiveSession = result.Session;
            await RefreshSessionsAsync();
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void OnSelectedToolChanged(ChangeEventArgs args)
    {
        SelectedToolName = args.Value?.ToString() ?? string.Empty;
        ToolApproved = false;
        ToolResultJson = null;
        ToolArgumentsText = SelectedToolName switch
        {
            "shell.run" => "command=git status --short",
            "workspace.find_files" => "pattern=*.csproj\nmaxResults=20",
            "workspace.read_file" => "path=README.md\nmaxBytes=4096",
            "workspace.write_file" => "path=.tmp/ui-write-test.txt\ncontent=hello from DinoAI UI\noverwrite=true",
            _ => string.Empty
        };
    }

    private async Task ExecuteSelectedToolAsync()
    {
        if (string.IsNullOrWhiteSpace(SelectedToolName))
        {
            return;
        }

        IsToolBusy = true;
        ToolResultJson = null;

        try
        {
            var arguments = ParseArguments(ToolArgumentsText);
            var result = await Tools.ExecuteAsync(
                SelectedToolName,
                new AgentToolContext(WorkspaceRoot, arguments, ToolApproved));

            LastToolSucceeded = result.IsSuccess;
            ToolResultJson = JsonSerializer.Serialize(result, JsonOptions);
        }
        finally
        {
            IsToolBusy = false;
        }
    }

    private static IReadOnlyDictionary<string, string?> ParseArguments(string text)
    {
        var arguments = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);
        foreach (var rawLine in text.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var separator = rawLine.IndexOf('=');
            if (separator <= 0)
            {
                continue;
            }

            arguments[rawLine[..separator].Trim()] = rawLine[(separator + 1)..].Trim();
        }

        return arguments;
    }
}
