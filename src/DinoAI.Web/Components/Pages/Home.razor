@page "/"
@rendermode InteractiveServer
@using System.Net
@using System.Text
@using System.Text.Json
@using System.Text.RegularExpressions
@using Microsoft.JSInterop
@using DinoAI.Core.Agents
@using DinoAI.Core.Models
@using DinoAI.Core.Sessions
@using DinoAI.Core.Tools
@using DinoAI.Core.Workspace
@inject IAgentSessionStore Sessions
@inject IAgentRunner Agent
@inject IChatModelProvider ModelProvider
@inject IChatModelSettingsStore ModelSettings
@inject IWorkspaceService Workspace
@inject IJSRuntime JS
@inject IAgentToolRegistry Tools

<PageTitle>DinoAI</PageTitle>

<section class="dino-app">
    <aside class="session-sidebar">
        <div class="sidebar-heading">
            <div>
                <p class="eyebrow">Проект</p>
                <h2>DinoAI</h2>
            </div>
            <button class="icon-button" title="Новая сессия" @onclick="CreateSessionAsync">+</button>
        </div>

        <div class="workspace-mini">
            <span>Рабочая папка</span>
            <strong>@WorkspaceRoot</strong>
        </div>

        <div class="session-list">
            @if (SessionList.Count == 0)
            {
                <p class="empty small">Сессий пока нет.</p>
            }
            else
            {
                @foreach (var session in SessionList)
                {
                    <button class="session-tab @(ActiveSession?.Id == session.Id ? "active" : null)" @onclick="() => SelectSessionAsync(session.Id)">
                        <strong>@GetSessionTitle(session)</strong>
                        <span>@session.Messages.Count сообщ.</span>
                        <time>@session.UpdatedAt.LocalDateTime.ToString("g")</time>
                    </button>
                }
            }
        </div>
    </aside>

    <main class="dino-shell">
        <header class="app-topbar">
            <div>
                <p class="eyebrow">Локальный агент</p>
                <h1>@(ActiveSession is null ? "Новая сессия" : GetSessionTitle(ActiveSession))</h1>
            </div>

            <div class="topbar-actions">
                <span class="model-pill @ModelStateClass">@ModelStateLabel</span>
                <button class="secondary" @onclick="ToggleToolsPanel">Инструменты</button>
                <button class="secondary" @onclick="ToggleSettingsPanel">Настройки</button>
                <button class="primary" @onclick="CreateSessionAsync">Новая сессия</button>
            </div>
        </header>

        <section class="agent-workbench">
            <div class="agent-main">
        <section class="context-strip">
            <div>
                <span>Модель</span>
                <strong>@(ModelStatus.Model ?? "не выбрана")</strong>
            </div>
            <div>
                <span>Проекты</span>
                <strong>@ProjectFiles.Count файлов</strong>
            </div>
            <div>
                <span>Команды</span>
                <strong>/workspace /files /read /build</strong>
            </div>
        </section>

        @if (ShowSettings)
        {
            <section class="settings-panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Настройки</p>
                        <h2>Провайдер модели</h2>
                        <p class="summary">@ModelStatusSummary</p>
                    </div>
                    <button class="icon-button" title="Закрыть настройки" @onclick="ToggleSettingsPanel">x</button>
                </div>

                <div class="model-settings-form">
                    <label>
                        Базовый адрес
                        <input @bind="ModelBaseUrl" @bind:event="oninput" placeholder="https://openrouter.ai/api/v1" />
                    </label>

                    <label>
                        Модель
                        <input @bind="ModelName" @bind:event="oninput" placeholder="deepseek/deepseek-v4-flash" />
                    </label>

                    <label>
                        Ключ API
                        <input type="password" @bind="ModelApiKey" @bind:event="oninput" placeholder="sk-..." autocomplete="off" />
                    </label>

                    <div class="model-actions">
                        <button class="primary" @onclick="SaveModelSettingsAsync" disabled="@IsModelSettingsBusy">
                            @(IsModelSettingsBusy ? "Сохраняю..." : "Сохранить")
                        </button>
                        <button class="secondary" @onclick="TestModelSettingsAsync" disabled="@(IsModelSettingsBusy || !ModelStatus.IsConfigured)">
                            Проверить подключение
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(ModelSettingsMessage))
                    {
                        <p class="settings-message @(LastModelSettingsSucceeded ? "success" : "failure")">@ModelSettingsMessage</p>
                    }
                </div>
            </section>
        }

        @if (ShowTools)
        {
            <section class="tools-panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Инструменты</p>
                        <h2>Ручной запуск</h2>
                    </div>
                    <span>@ToolDefinitions.Count инстр.</span>
                </div>

                <div class="tool-list">
                    @foreach (var tool in ToolDefinitions)
                    {
                        <span title="@tool.Description">@tool.Name</span>
                    }
                </div>

                <div class="tool-runner">
                    <label>
                        Инструмент
                        <select value="@SelectedToolName" @onchange="OnSelectedToolChanged">
                            @foreach (var tool in ToolDefinitions)
                            {
                                <option value="@tool.Name">@tool.Name</option>
                            }
                        </select>
                    </label>

                    <label>
                        Корень workspace
                        <input @bind="WorkspaceRoot" @bind:event="oninput" />
                    </label>

                    <label class="approval-toggle">
                        <input type="checkbox" @bind="ToolApproved" />
                        Явно разрешить этот вызов инструмента
                    </label>

                    @if (SelectedTool is not null)
                    {
                        <div class="tool-description">
                            <strong>@SelectedTool.Name</strong>
                            <span>@SelectedTool.Description</span>
                        </div>

                        <div class="parameter-list">
                            @foreach (var parameter in SelectedTool.Parameters)
                            {
                                <span>@parameter.Name @(parameter.IsRequired ? "обяз." : $"по умолч. {parameter.DefaultValue}")</span>
                            }
                        </div>
                    }

                    <label>
                        Аргументы
                        <textarea @bind="ToolArgumentsText" @bind:event="oninput" rows="5" placeholder="key=value&#10;command=git status --short&#10;timeoutSeconds=30"></textarea>
                    </label>

                    <button class="primary" @onclick="ExecuteSelectedToolAsync" disabled="@(IsToolBusy || string.IsNullOrWhiteSpace(SelectedToolName))">
                        @(IsToolBusy ? "Инструмент выполняется..." : "Запустить инструмент")
                    </button>

                    @if (!string.IsNullOrWhiteSpace(ToolResultJson))
                    {
                        <pre class="tool-result @(LastToolSucceeded ? "success" : "failure")">@ToolResultJson</pre>
                    }
                </div>
            </section>
        }

        <section class="chat-panel" @ref="ChatPanel">
            @if (ActiveSession is null)
            {
                <div class="empty-chat">
                    <h2>Создай сессию</h2>
                    <p>После этого можно писать обычные вопросы или локальные команды.</p>
                </div>
            }
            else
            {
                <div class="messages">
                    @if (ActiveSession.Messages.Count == 0)
                    {
                        <div class="empty-chat compact">
                            <h2>Чем займёмся?</h2>
                            <p>Напиши задачу, вопрос по проекту или команду вроде <code>/workspace</code>.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var message in ActiveSession.Messages)
                        {
                            <div class="message @message.Role.ToString().ToLowerInvariant()">
                                <strong>@GetRoleLabel(message.Role)</strong>
                                <div class="message-content">@RenderMessageContent(message.Content)</div>
                            </div>
                        }
                    }
                </div>
            }
        </section>

        <div class="quick-actions">
            <button class="quick-action" @onclick="UseWorkspaceCommand">/workspace</button>
            <button class="quick-action" @onclick="UseFilesCommand">/files *.csproj</button>
            <button class="quick-action" @onclick="UseReadmeCommand">/read README.md</button>
            <button class="quick-action" @onclick="UseBuildCommand">/build</button>
        </div>

        <div class="composer">
            <textarea @bind="DraftMessage" @bind:event="oninput" rows="2" placeholder="Напиши задачу или команду: /workspace, /files *.csproj, /read README.md, /build"></textarea>
            <button @onclick="SendMessageAsync" disabled="@(ActiveSession is null || IsBusy || string.IsNullOrWhiteSpace(DraftMessage))">
                @(IsBusy ? "Думаю..." : "Отправить")
            </button>
        </div>
            </div>

            <aside class="inspector-panel">
                <section class="inspector-card session-card">
                    <p class="eyebrow">Сессия</p>
                    <h2>@(ActiveSession is null ? "Новая сессия" : GetSessionTitle(ActiveSession))</h2>
                    <span>@(ActiveSession?.Id.ToString("N")[..8] ?? "draft")</span>
                </section>

                <section class="inspector-card">
                    <div class="inspector-heading">
                        <h3>Context</h3>
                        <span>@ContextUsedPercent%</span>
                    </div>
                    <div class="meter"><span style="width: @ContextUsedPercent%"></span></div>
                    <dl>
                        <div><dt>Сообщения</dt><dd>@(ActiveSession?.Messages.Count ?? 0)</dd></div>
                        <div><dt>Оценка токенов</dt><dd>@ContextTokenEstimate</dd></div>
                        <div><dt>Workspace</dt><dd>@ProjectFiles.Count csproj</dd></div>
                    </dl>
                </section>

                <section class="inspector-card">
                    <div class="inspector-heading">
                        <h3>Model</h3>
                        <span class="dot @ModelStateClass"></span>
                    </div>
                    <strong>@(ModelStatus.Model ?? "не выбрана")</strong>
                    <p>@ModelStateLabel</p>
                </section>

                <section class="inspector-card">
                    <div class="inspector-heading">
                        <h3>Tools</h3>
                        <span>@ToolDefinitions.Count</span>
                    </div>
                    <div class="mini-tool-list">
                        @foreach (var tool in ToolDefinitions.Take(6))
                        {
                            <span>@tool.Name</span>
                        }
                    </div>
                </section>

                <section class="inspector-card muted-card">
                    <h3>LSP</h3>
                    <p>Активируется, когда DinoAI начнет читать и индексировать файлы проекта.</p>
                </section>
            </aside>
        </section>
    </main>
</section>

@code {
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web)
    {
        WriteIndented = true
    };

    private ElementReference ChatPanel { get; set; }

    private bool ShouldScrollChat { get; set; }

    private AgentSession? ActiveSession { get; set; }

    private string DraftMessage { get; set; } = string.Empty;

    private string WorkspaceRoot { get; set; } = WorkspaceRootResolver.Resolve(Directory.GetCurrentDirectory());

    private bool IsBusy { get; set; }

    private bool IsToolBusy { get; set; }

    private bool ToolApproved { get; set; }

    private bool LastToolSucceeded { get; set; }

    private bool ShowSettings { get; set; }

    private bool ShowTools { get; set; }

    private string SelectedToolName { get; set; } = string.Empty;

    private string ToolArgumentsText { get; set; } = "command=git status --short";

    private string? ToolResultJson { get; set; }

    private string ModelBaseUrl { get; set; } = string.Empty;

    private string ModelApiKey { get; set; } = string.Empty;

    private string ModelName { get; set; } = string.Empty;

    private string? ModelSettingsMessage { get; set; }

    private bool IsModelSettingsBusy { get; set; }

    private bool LastModelSettingsSucceeded { get; set; }

    private bool IsModelConnectionVerified { get; set; }

    private ChatModelProviderStatus ModelStatus { get; set; } = ChatModelProviderStatus.NotConfigured("OpenAI-compatible", "Модель еще не проверена.");

    private string ModelStateClass => !ModelStatus.IsConfigured
        ? "missing"
        : IsModelConnectionVerified
            ? "ready"
            : "pending";

    private string ModelStateLabel => !ModelStatus.IsConfigured
        ? "не настроено"
        : IsModelConnectionVerified
            ? "проверено"
            : "ключ задан";

    private string ModelStatusSummary => !ModelStatus.IsConfigured
        ? ModelStatus.Reason ?? "Модель не настроена."
        : IsModelConnectionVerified
            ? $"Подключение проверено, активная модель: {ModelStatus.Model}."
            : $"Ключ задан, активная модель: {ModelStatus.Model}. Нажми «Проверить подключение», чтобы убедиться, что API отвечает.";

    private IReadOnlyList<AgentSession> SessionList { get; set; } = [];

    private IReadOnlyList<WorkspaceFile> ProjectFiles { get; set; } = [];

    private IReadOnlyList<AgentToolDefinition> ToolDefinitions { get; set; } = [];

    private AgentToolDefinition? SelectedTool => ToolDefinitions.FirstOrDefault(tool => tool.Name == SelectedToolName);

    private int ContextTokenEstimate => ActiveSession?.Messages.Sum(message => Math.Max(1, message.Content.Length / 4)) ?? 0;

    private int ContextUsedPercent => Math.Clamp(ContextTokenEstimate / 80, 0, 100);

    protected override async Task OnInitializedAsync()
    {
        await LoadModelSettingsAsync();
        await RefreshSessionsAsync();
        ActiveSession = SessionList.FirstOrDefault() ?? await Sessions.CreateAsync("Сессия DinoAI");
        await RefreshSessionsAsync();
        ProjectFiles = await Workspace.FindFilesAsync(WorkspaceRoot, "*.csproj", 20);
        ToolDefinitions = Tools.List();
        SelectedToolName = ToolDefinitions.FirstOrDefault()?.Name ?? string.Empty;
        ShouldScrollChat = true;
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!ShouldScrollChat)
        {
            return;
        }

        ShouldScrollChat = false;
        await JS.InvokeVoidAsync("dinoAI.scrollChatToBottom", ChatPanel);
    }

    private void ToggleSettingsPanel()
    {
        ShowSettings = !ShowSettings;
        if (ShowSettings)
        {
            ShowTools = false;
        }
    }

    private void ToggleToolsPanel()
    {
        ShowTools = !ShowTools;
        if (ShowTools)
        {
            ShowSettings = false;
        }
    }

    private async Task LoadModelSettingsAsync()
    {
        var options = await ModelSettings.GetAsync();
        ModelBaseUrl = options.BaseUrl;
        ModelApiKey = options.ApiKey ?? string.Empty;
        ModelName = options.Model;
        ModelStatus = ModelProvider.GetStatus();
    }

    private async Task SaveModelSettingsAsync()
    {
        IsModelSettingsBusy = true;
        ModelSettingsMessage = null;

        try
        {
            await ModelSettings.SaveAsync(new OpenAICompatibleChatModelOptions(ModelBaseUrl, ModelApiKey, ModelName));
            ModelStatus = ModelProvider.GetStatus();
            IsModelConnectionVerified = false;
            LastModelSettingsSucceeded = true;
            ModelSettingsMessage = ModelStatus.IsConfigured
                ? "Настройки модели сохранены. Теперь проверь подключение."
                : "Настройки модели сохранены, но ключ API не задан.";
        }
        catch (Exception ex) when (ex is ArgumentException or IOException)
        {
            LastModelSettingsSucceeded = false;
            ModelSettingsMessage = $"Не удалось сохранить настройки: {ex.Message}";
        }
        finally
        {
            IsModelSettingsBusy = false;
        }
    }

    private async Task TestModelSettingsAsync()
    {
        IsModelSettingsBusy = true;
        ModelSettingsMessage = null;

        try
        {
            var response = await ModelProvider.CompleteAsync(new ChatModelRequest([
                new ChatModelMessage("system", "Ты проверяешь подключение DinoAI к модели. Ответь одним коротким русским предложением."),
                new ChatModelMessage("user", "Проверка подключения.")
            ], Temperature: 0));

            ModelStatus = ModelProvider.GetStatus();
            IsModelConnectionVerified = true;
            LastModelSettingsSucceeded = true;
            ModelSettingsMessage = $"Подключение работает: {response.Content}";
        }
        catch (Exception ex) when (ex is InvalidOperationException or HttpRequestException or TaskCanceledException)
        {
            ModelStatus = ModelProvider.GetStatus();
            IsModelConnectionVerified = false;
            LastModelSettingsSucceeded = false;
            ModelSettingsMessage = ex.Message.StartsWith("Проверка не прошла", StringComparison.Ordinal)
                ? ex.Message
                : $"Проверка не прошла: {ex.Message}";
        }
        finally
        {
            IsModelSettingsBusy = false;
        }
    }

    private async Task RefreshSessionsAsync()
    {
        SessionList = await Sessions.ListAsync();
    }

    private async Task CreateSessionAsync()
    {
        ActiveSession = await Sessions.CreateAsync("Сессия DinoAI");
        DraftMessage = string.Empty;
        ShouldScrollChat = true;
        await RefreshSessionsAsync();
    }

    private async Task SelectSessionAsync(Guid sessionId)
    {
        ActiveSession = await Sessions.GetAsync(sessionId);
        DraftMessage = string.Empty;
        ShouldScrollChat = true;
    }

    private void UseWorkspaceCommand() => UseQuickCommand("/workspace");

    private void UseFilesCommand() => UseQuickCommand("/files *.csproj");

    private void UseReadmeCommand() => UseQuickCommand("/read README.md");

    private void UseBuildCommand() => UseQuickCommand("/build");

    private void UseQuickCommand(string command)
    {
        DraftMessage = command;
    }

    private async Task SendMessageAsync()
    {
        if (ActiveSession is null || string.IsNullOrWhiteSpace(DraftMessage))
        {
            return;
        }

        IsBusy = true;
        var message = DraftMessage;
        DraftMessage = string.Empty;

        try
        {
            var result = await Agent.RunAsync(ActiveSession.Id, WorkspaceRoot, message);
            ActiveSession = result.Session;
            ShouldScrollChat = true;
            await RefreshSessionsAsync();
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void OnSelectedToolChanged(ChangeEventArgs args)
    {
        SelectedToolName = args.Value?.ToString() ?? string.Empty;
        ToolApproved = false;
        ToolResultJson = null;
        ToolArgumentsText = SelectedToolName switch
        {
            "shell.run" => "command=git status --short",
            "workspace.find_files" => "pattern=*.csproj\nmaxResults=20",
            "workspace.read_file" => "path=README.md\nmaxBytes=4096",
            "workspace.write_file" => "path=.tmp/ui-write-test.txt\ncontent=hello from DinoAI UI\noverwrite=true",
            _ => string.Empty
        };
    }

    private async Task ExecuteSelectedToolAsync()
    {
        if (string.IsNullOrWhiteSpace(SelectedToolName))
        {
            return;
        }

        IsToolBusy = true;
        ToolResultJson = null;

        try
        {
            var arguments = ParseArguments(ToolArgumentsText);
            var result = await Tools.ExecuteAsync(
                SelectedToolName,
                new AgentToolContext(WorkspaceRoot, arguments, ToolApproved));

            LastToolSucceeded = result.IsSuccess;
            ToolResultJson = JsonSerializer.Serialize(result, JsonOptions);
        }
        finally
        {
            IsToolBusy = false;
        }
    }

    private static IReadOnlyDictionary<string, string?> ParseArguments(string text)
    {
        var arguments = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);
        foreach (var rawLine in text.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var separator = rawLine.IndexOf('=');
            if (separator <= 0)
            {
                continue;
            }

            arguments[rawLine[..separator].Trim()] = rawLine[(separator + 1)..].Trim();
        }

        return arguments;
    }

    private static MarkupString RenderMessageContent(string content)
    {
        return new MarkupString(BuildMessageHtml(content));
    }

    private static string BuildMessageHtml(string content)
    {
        if (string.IsNullOrWhiteSpace(content))
        {
            return "<p></p>";
        }

        var builder = new StringBuilder();
        var inCodeBlock = false;

        foreach (var line in content.Split('\n'))
        {
            var normalizedLine = line.TrimEnd('\r');
            if (normalizedLine.TrimStart().StartsWith("```", StringComparison.Ordinal))
            {
                builder.Append(inCodeBlock ? "</code></pre>" : "<pre><code>");
                inCodeBlock = !inCodeBlock;
                continue;
            }

            if (inCodeBlock)
            {
                builder.Append(WebUtility.HtmlEncode(normalizedLine));
                builder.Append('\n');
                continue;
            }

            if (string.IsNullOrWhiteSpace(normalizedLine))
            {
                builder.Append("<br />");
                continue;
            }

            builder.Append("<p>");
            builder.Append(FormatInlineMarkdown(normalizedLine));
            builder.Append("</p>");
        }

        if (inCodeBlock)
        {
            builder.Append("</code></pre>");
        }

        return builder.ToString();
    }

    private static string FormatInlineMarkdown(string line)
    {
        var encoded = WebUtility.HtmlEncode(line);
        encoded = Regex.Replace(encoded, @"`([^`]+)`", "<code>$1</code>");
        encoded = Regex.Replace(encoded, @"\*\*([^*]+)\*\*", "<strong>$1</strong>");
        return encoded;
    }

    private static string GetSessionTitle(AgentSession session)
    {
        return session.Title switch
        {
            "Blazor workspace session" => "Сессия DinoAI",
            "CLI ask session" => "CLI-сессия",
            _ => session.Title
        };
    }

    private static string GetRoleLabel(AgentMessageRole role)
    {
        return role switch
        {
            AgentMessageRole.User => "Пользователь",
            AgentMessageRole.Assistant => "Ассистент",
            AgentMessageRole.Tool => "Инструмент",
            AgentMessageRole.System => "Система",
            _ => role.ToString()
        };
    }
}

